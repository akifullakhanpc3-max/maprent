# Server Configuration
PORT=5050
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_BUCKET=property-images

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# External APIs
GEMINI_API_KEY=your_gemini_api_key

# Seed Data Credentials (Used by scripts)
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_PASSWORD=admin_password_123
STAFF_EMAIL=staff@example.com
STAFF_PASSWORD=staff_password_123
VITE_FIREBASE_API_KEY=your_firebase_client_api_key
